# ENTSO-E API key (request via transparency@entsoe.eu, subject: "Restful API access")
ENTSOE_API_KEY=your_entsoe_api_key_here

# CDS API token (from ~/.cdsapirc or https://cds.climate.copernicus.eu/api)
CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=your_cds_api_key_here

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west4
GCS_BUCKET=dev-renewable-energy-europe

# Country scope
COUNTRY=GR
START_DATE=2025-03-01
END_DATE=2025-03-07
